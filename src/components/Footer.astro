---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer__grid">
      <div>
        <div class="footer__brand">DC Custom Guitars</div>
        <p class="footer__about">
          Master luthier Dean Cascione hand-builds custom electric guitars and offers
          world-class scalloping services from his shop in Rochdale, MA.
        </p>
        <div class="footer__socials">
          <a
            href="https://www.facebook.com/dccustomguitars/"
            target="_blank"
            rel="noopener"
            class="footer__social"
            aria-label="Facebook"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/>
            </svg>
          </a>
          <a
            href="mailto:info@dccustomguitars.com"
            class="footer__social"
            aria-label="Email"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="4" width="20" height="16" rx="2"/>
              <path d="m22 7-10 5L2 7"/>
            </svg>
          </a>
        </div>
      </div>

      <div class="footer__col">
        <h4>Shop</h4>
        <ul>
          <li><a href="#builds">Evolin</a></li>
          <li><a href="#builds">Super Shred (SS)</a></li>
          <li><a href="#builds">Custom Mods</a></li>
        </ul>
      </div>

      <div class="footer__col">
        <h4>Services</h4>
        <ul>
          <li><a href="#scalloping">Full Scallop</a></li>
          <li><a href="#scalloping">Partial Scallop</a></li>
          <li><a href="#scalloping">Mail-Order</a></li>
        </ul>
      </div>

      <div class="footer__col">
        <h4>Contact</h4>
        <ul>
          <li><a href="mailto:info@dccustomguitars.com">info@dccustomguitars.com</a></li>
          <li>Dean Cascione</li>
          <li>608 Henshaw Street</li>
          <li>Rochdale, MA 01542</li>
        </ul>
      </div>
    </div>

    <div class="footer__bottom">
      <span>© {year} DC Custom Guitars USA. All rights reserved.</span>
      <span>Hand-built in Massachusetts</span>
    </div>
  </div>
</footer>
