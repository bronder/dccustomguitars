---
// Hero — full-bleed, image-backed, big display type
import { Picture } from 'astro:assets';
import heroImg from '~/assets/images/evolin_bandmaster_jacket_copy_1600.jpg';
---

<section class="hero" id="top">
  <div class="hero__media">
    <Picture
      class="hero__img"
      src={heroImg}
      alt="DC Custom Guitars Evolin model — hand-built by Dean Cascione"
      layout="full-width"
      loading="eager"
      widths={[480, 768, 1024, 1280, 1600]}
      sizes="100vw"
    />
  </div>

  <div class="container hero__inner">
    <span class="hero__eyebrow">Master Luthier · Rochdale, MA</span>

    <h1 class="hero__title">
      Built by hand.<br />
      <em>Played for life.</em>
    </h1>

    <p class="hero__lead">
      DC Custom Guitars specializes in building unique custom instruments and
      world-class fretboard scalloping. Every guitar leaves the shop built, finished,
      wired, and set up personally by Dean Cascione.
    </p>

    <div class="hero__actions">
      <a href="#builds" class="btn btn--primary btn--lg">Explore the Builds</a>
      <a href="#scalloping" class="btn btn--ghost btn--lg">Scalloping Service</a>
    </div>

    <div class="hero__stats">
      <div class="hero__stat">
        <span class="hero__stat-num">20+</span>
        <span class="hero__stat-label">Years Building</span>
      </div>
      <div class="hero__stat">
        <span class="hero__stat-num">19</span>
        <span class="hero__stat-label">Endorsed Artists</span>
      </div>
      <div class="hero__stat">
        <span class="hero__stat-num">100%</span>
        <span class="hero__stat-label">Hand Built in USA</span>
      </div>
    </div>
  </div>
</section>
