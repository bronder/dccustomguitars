---
// Recent Builds gallery — masonry grid + lightbox
import { Image, getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro:assets';
import g01 from '~/assets/images/gallery/gallery_01.jpg';
import g02 from '~/assets/images/gallery/gallery_02.jpg';
import g03 from '~/assets/images/gallery/gallery_03.jpg';
import g04 from '~/assets/images/gallery/gallery_04.jpg';
import g05 from '~/assets/images/gallery/gallery_05.jpg';
import g06 from '~/assets/images/gallery/gallery_06.jpg';
import g07 from '~/assets/images/gallery/gallery_07.jpg';
import g08 from '~/assets/images/gallery/gallery_08.jpg';
import g09 from '~/assets/images/gallery/gallery_09.jpg';
import g10 from '~/assets/images/gallery/gallery_10.jpg';
import g11 from '~/assets/images/gallery/gallery_11.jpg';
import g12 from '~/assets/images/gallery/gallery_12.jpg';
import g13 from '~/assets/images/gallery/gallery_13.jpg';
import g14 from '~/assets/images/gallery/gallery_14.jpg';
import g15 from '~/assets/images/gallery/gallery_15.jpg';
import g16 from '~/assets/images/gallery/gallery_16.jpg';

const galleryPhotos: Array<{ src: ImageMetadata; alt: string }> = [
  { src: g01, alt: 'DC Custom Guitars hand-built electric guitar in studio lighting' },
  { src: g02, alt: 'DC Custom Guitars finished build with detailed fretwork' },
  { src: g03, alt: 'DC Custom Guitars custom build with premium tonewoods' },
  { src: g04, alt: 'DC Custom Guitars build with sculpted body contours' },
  { src: g05, alt: 'DC Custom Guitars build showing pickup and hardware detail' },
  { src: g06, alt: 'DC Custom Guitars finished guitar with custom finish' },
  { src: g07, alt: 'DC Custom Guitars recent build with reverse headstock' },
  { src: g08, alt: 'DC Custom Guitars build with Floyd Rose tremolo system' },
  { src: g09, alt: 'DC Custom Guitars custom guitar with detailed inlay work' },
  { src: g10, alt: 'DC Custom Guitars wide body shot showing figured wood grain' },
  { src: g11, alt: 'DC Custom Guitars build in progress on the workbench' },
  { src: g12, alt: 'DC Custom Guitars finished build with brass hardware' },
  { src: g13, alt: 'DC Custom Guitars recent custom guitar build' },
  { src: g14, alt: 'DC Custom Guitars custom guitar with detailed fretboard' },
  { src: g15, alt: 'DC Custom Guitars finished build with custom color finish' },
  { src: g16, alt: 'DC Custom Guitars endorsed artist build' },
];

// Generate optimized full-size images for the lightbox instead of serving the
// multi-megabyte originals. Width 1600 balances detail and file size for a
// full-viewport overlay; webp gives a strong size/quality ratio with broad
// browser support.
const photos = await Promise.all(
  galleryPhotos.map(async (photo) => {
    const full = await getImage({
      src: photo.src,
      width: 1600,
      format: 'webp',
      quality: 78,
    });
    return { ...photo, fullSrc: full.src };
  }),
);
---

<section class="section" id="gallery">
  <div class="container">
    <div class="section-head">
      <span class="section-eyebrow">Recent Builds</span>
      <h2 class="section-title">The portfolio.</h2>
      <p class="section-subtitle">
        A selection of instruments built, finished, and set up by Dean Cascione
        — from signature models to one-off customs, spanning over a decade of work.
      </p>
    </div>

    <div class="gallery__grid">
      {photos.map((photo, i) => (
        <button
          class="gallery__item"
          data-full={photo.fullSrc}
          data-index={i}
          aria-label={`View photo ${i + 1}: ${photo.alt}`}
        >
          <Image
            src={photo.src}
            alt={photo.alt}
            loading={i < 4 ? 'eager' : 'lazy'}
            widths={[300, 400, 500, 640]}
            sizes="(max-width: 540px) 100vw, 50vw"
          />
        </button>
      ))}
    </div>
  </div>

  <!-- Lightbox overlay -->
  <div class="gallery__lightbox" id="galleryLightbox" aria-hidden="true">
    <button class="gallery__close" id="galleryClose" aria-label="Close gallery">&times;</button>
    <button class="gallery__nav gallery__nav--prev" id="galleryPrev" aria-label="Previous photo">&#8249;</button>
    <img class="gallery__fullimg" id="galleryFullImg" src="" alt="" />
    <button class="gallery__nav gallery__nav--next" id="galleryNext" aria-label="Next photo">&#8250;</button>
  </div>
</section>

<script>
  const lightbox = document.getElementById('galleryLightbox');
  const fullImg = document.getElementById('galleryFullImg') as HTMLImageElement | null;
  const closeBtn = document.getElementById('galleryClose');
  const prevBtn = document.getElementById('galleryPrev');
  const nextBtn = document.getElementById('galleryNext');
  const items = document.querySelectorAll<HTMLButtonElement>('.gallery__item');

  let currentIndex = 0;

  function open(index: number) {
    currentIndex = index;
    showImage();
    lightbox?.classList.add('is-open');
    lightbox?.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function close() {
    lightbox?.classList.remove('is-open');
    lightbox?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  function showImage() {
    const item = items[currentIndex];
    if (item && fullImg) {
      fullImg.src = item.dataset.full ?? '';
      fullImg.alt = item.getAttribute('aria-label') ?? '';
    }
  }

  function next() {
    currentIndex = (currentIndex + 1) % items.length;
    showImage();
  }

  function prev() {
    currentIndex = (currentIndex - 1 + items.length) % items.length;
    showImage();
  }

  items.forEach((item, i) => {
    item.addEventListener('click', () => open(i));
  });

  closeBtn?.addEventListener('click', close);
  nextBtn?.addEventListener('click', (e) => { e.stopPropagation(); next(); });
  prevBtn?.addEventListener('click', (e) => { e.stopPropagation(); prev(); });

  // Click outside the image closes
  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox) close();
  });

  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    if (!lightbox?.classList.contains('is-open')) return;
    if (e.key === 'Escape') close();
    if (e.key === 'ArrowRight') next();
    if (e.key === 'ArrowLeft') prev();
  });
</script>
