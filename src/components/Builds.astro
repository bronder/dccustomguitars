---
// Custom Builds showcase
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro:assets';
import evolinImg from '~/assets/images/evolin_dc_custom_guitars_usa.jpg';
import superShredImg from '~/assets/images/super_strat_jack_butler_style.jpg';
import reverseHendrixImg from '~/assets/images/dc_custom_reverse_hendrix.jpg';
import moddedVImg from '~/assets/images/sequon_yoon_modded_gibson_v_single_pickups.jpg';
import moddedEspImg from '~/assets/images/joe_stump_modded_esp_ltd_scallops.jpg';
import lineupImg from '~/assets/images/dc_custom_models_1600.jpg';
import explodedImg from '~/assets/images/evolin_exploded_view.jpg';

interface Build {
  name: string;
  badge: string;
  image: ImageMetadata;
  alt: string;
  description: string;
  specs: Array<[string, string]>;
  price: string;
  priceNote: string;
}

const builds: Build[] = [
  {
    name: 'DC Custom Evolin',
    badge: 'Bestseller',
    image: evolinImg,
    alt: 'DC Custom Evolin signature model electric guitar',
    description:
      "Dean's signature instrument. A modern superstrat with a sculpted body, premium tonewoods, and uncompromising build quality. Built to your spec from the ground up.",
    specs: [
      ['Body', 'Alder / Mahogany'],
      ['Neck', 'Bolt-on or Set'],
      ['Scale', '25.5"'],
      ['Frets', '22–24'],
    ],
    price: '$3,500',
    priceNote: 'Includes USA shipping',
  },
  {
    name: 'Super Shred (SS/RR)',
    badge: 'Pro Choice',
    image: superShredImg,
    alt: 'DC Custom Super Shred (SS/RR) rear-route signature model',
    description:
      'Built for the player who lives in the upper register. Rear-route (RR) configuration with the hottest pickups and the most aggressive specs.',
    specs: [
      ['Config', 'Rear Route (RR)'],
      ['Bridge', 'Floyd Rose / Kahler'],
      ['Neck', 'Bolt-on Maple'],
      ['Pickups', 'Your choice'],
    ],
    price: '$3,000',
    priceNote: 'Includes USA shipping',
  },
  {
    name: 'Summer of Love Purple Craze DC',
    badge: 'Custom Build',
    image: reverseHendrixImg,
    alt: 'DC Custom Summer of Love Purple Craze custom guitar',
    description:
      "A psychedelic standout in the DC Custom lineup. Vibrant purple finish, vintage-inspired contours, and reverse headstock — built for the player who wants tone and a look that turns heads.",
    specs: [
      ['Style', 'Reverse headstock'],
      ['Body', 'To your spec'],
      ['Fretboard', 'Rosewood / Maple'],
      ['Finish', 'Custom color'],
    ],
    price: 'Custom',
    priceNote: 'Quote on request',
  },
  {
    name: 'Modded Flying V',
    badge: 'Recent Build',
    image: moddedVImg,
    alt: 'DC Custom modded Gibson Flying V with SSS pickup configuration',
    description:
      "Bought a guitar that doesn't have the right tone, function, or feel? We'll rework contours, install new pickups, custom wire, add a tremolo, or block the bridge.",
    specs: [
      ['Type', 'Custom mod'],
      ['Pickups', 'SSS / HH'],
      ['Bridge', 'Kahler / Hardtail'],
      ['Pickguard', 'Custom cut'],
    ],
    price: 'From $500',
    priceNote: 'Quote on request',
  },
  {
    name: 'Modded ESP / LTD',
    badge: 'Client Build',
    image: moddedEspImg,
    alt: "DC Custom modded ESP LTD with Joe Stump scallops",
    description:
      "One of Joe Stump's personal builds. The same scallop job, pickup swap, and setup that pro players trust for their working instruments.",
    specs: [
      ['Type', 'Existing guitar'],
      ['Service', 'Scallop + rewire'],
      ['Pickups', 'Seymour Duncan'],
      ['Setup', 'Pro playability'],
    ],
    price: 'Custom',
    priceNote: 'Quote on request',
  },
];

const processSteps = [
  {
    num: '01',
    title: 'Spec It Out',
    detail: 'Work hand-in-hand with Dean to choose body wood, neck profile, fretboard, inlays, pickups, hardware, and finish — from napkin sketch to final spec.',
  },
  {
    num: '02',
    title: 'Secure Your Slot',
    detail: 'A 50% deposit holds your place in the build queue. Dean personally builds every guitar, so slots are limited.',
  },
  {
    num: '03',
    title: 'Watch It Come To Life',
    detail: 'Over ~6 months, progress photos are sent throughout the entire build — you see your guitar take shape from raw wood to final setup.',
  },
  {
    num: '04',
    title: 'Play It Forever',
    detail: 'Built, finished, wired, assembled, and set up by Dean. Shipped to your door in the USA — ready to play for life.',
  },
];
---

<section class="section section--elevated" id="builds">
  <div class="container">
    <div class="section-head">
      <span class="section-eyebrow">Custom Builds</span>
      <h2 class="section-title">Three signatures.<br />Endless configurations.</h2>
      <p class="section-subtitle">
        Every DC Custom guitar is built to your spec — body wood, neck profile,
        fretboard, inlays, pickups, hardware, finish. Your guitar, your way.
      </p>
    </div>

    <div class="builds__grid">
      {builds.map(build => (
        <article class="build-card">
          <div class="build-card__media">
            <span class="build-card__badge">{build.badge}</span>
            <Picture
              src={build.image}
              alt={build.alt}
              loading="lazy"
              widths={[300, 400, 500, 640]}
              sizes="(max-width: 380px) 100vw, (max-width: 880px) 50vw, 360px"
            />
          </div>
          <div class="build-card__body">
            <h3 class="build-card__title">{build.name}</h3>
            <p class="build-card__desc">{build.description}</p>
            <div class="build-card__meta">
              {build.specs.map(([label, value]) => (
                <div class="build-card__meta-row">
                  <span class="build-card__meta-label">{label}</span>
                  <span class="build-card__meta-value">{value}</span>
                </div>
              ))}
            </div>
            <div class="build-card__price">
              <span class="build-card__price-label">{build.priceNote}</span>
              <span class="build-card__price-value">{build.price}</span>
            </div>
            <a
              class="build-card__cta btn btn--ghost"
              href={`mailto:info@dccustomguitars.com?subject=${encodeURIComponent(build.name + ' — Build Inquiry')}`}
            >
              Inquire about this build
            </a>
          </div>
        </article>
      ))}
    </div>

    <div class="customize">
      <h3 class="customize__title">What You Can Customize</h3>
      <p class="customize__lead">
        Every DC Custom build is made to order. Choose your spec across every
        option below — your guitar, built exactly the way you want it.
      </p>
      <ul class="customize__list">
        <li>Colors</li>
        <li>Body woods</li>
        <li>Neck profile &amp; shank</li>
        <li>Fretboard type</li>
        <li>Fretwire</li>
        <li>Pickups</li>
        <li>Bridge</li>
        <li>Tuners</li>
        <li>Hardware</li>
        <li>Inlays</li>
        <li>Finish</li>
      </ul>
      <p class="customize__note">All builds include shipping to the USA.</p>
    </div>

    <figure class="showcase">
      <Picture
        src={lineupImg}
        alt="Lineup of DC Custom Guitars signature models — Evolin and Super Shred"
        loading="lazy"
        widths={[480, 768, 1024, 1280, 1600]}
        sizes="(min-width: 1280px) 1280px, 100vw"
      />
      <figcaption>The DC Custom lineup — Evolin and Super Shred side by side.</figcaption>
    </figure>

    <figure class="showcase">
      <Picture
        src={explodedImg}
        alt="Exploded view of the DC Custom Evolin showing body, neck, hardware, and electronics"
        loading="lazy"
        widths={[480, 768, 1024, 1280, 1600]}
        sizes="(min-width: 1280px) 1280px, 100vw"
      />
      <figcaption>
        Evolin exploded view — every component hand-selected and assembled in-house.
      </figcaption>
    </figure>

    <div class="process">
      <div class="section-head process__head">
        <span class="section-eyebrow">The Build Process</span>
        <h2 class="section-title">From sketch<br />to shred.</h2>
      </div>
      <ol class="process__steps">
        {processSteps.map(step => (
          <li class="process__step">
            <span class="process__num">{step.num}</span>
            <h3 class="process__title">{step.title}</h3>
            <p class="process__detail">{step.detail}</p>
          </li>
        ))}
      </ol>
    </div>
  </div>
</section>
